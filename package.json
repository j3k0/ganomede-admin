{
  "name": "admin",
  "version": "1.8.1",
  "api": "admin/v1",
  "description": "admin panel for ganomede",
  "main": "index.js",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "test": "VIRTUAL_CURRENCY_CURRENCY_CODES=\"gold,silver,copper\" LOG_LEVEL=FATAL API_SECRET=1 mocha --bail --throw-deprecation tests/helper.js tests/",
    "testw": "nodemon --watch server/ --watch tests/ --exec 'npm run test'",
    "lintfix": "eslint --fix --ext js --ext jsx {index,config}.js server/ web/js/ tests/",
    "lint": "eslint --ext js --ext jsx {index,config}.js server/ web/js/ tests/",
    "lintw": "nodemon --ext js,jsx,json,eslintrc --watch server/ --watch tests/ --watch web/js --watch index.js --watch config.js --watch .eslintrc --watch package.json --watch web/js/.eslintrc --exec 'npm run lint'",
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --config vite.config.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "build:new": "vite build --config vite.config.ts && tsc -p tsconfig.server.json",
    "test:new": "vitest run",
    "test:new:watch": "vitest",
    "lint:new": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/j3k0/ganomede-admin.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "async": "^2.6.4",
    "awaitability": "0.0.1",
    "backbone": "^1.3.3",
    "body-parser": "^1.9.0",
    "bunyan": "^1.8.15",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ganomede-directory": "^0.3.5",
    "ganomede-errors": "^1.0.0",
    "ganomede-tagizer": "^2.0.1",
    "helmet": "^8.1.0",
    "jquery": "^3.5.1",
    "moment": "^2.25.3",
    "nodemailer": "^6.10.1",
    "passport": "^0.4.0",
    "passport-local": "^1.0.0",
    "password-generator": "^2.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "react-tabs": "^0.8.2",
    "react.backbone": "^0.9.0",
    "request": "^2.83.0",
    "serve-favicon": "^2.4.5",
    "sonner": "^2.0.7",
    "sweetalert": "^1.1.3",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-core": "^6.26.0",
    "babel-preset-es2017": "^6.24.1",
    "babel-preset-react": "^6.24.1",
    "babelify": "^8.0.0",
    "brfs": "^1.4.3",
    "browserify": "^15.0.0",
    "chai": "^4.1.2",
    "common-tags": "^1.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.4.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "expect.js": "^0.3.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "mocha": "^5.0.0",
    "msw": "^2.12.13",
    "nodemon": "^1.12.1",
    "prettier": "^3.8.1",
    "puppeteer": "^1.13.0",
    "supertest": "^7.2.2",
    "testdouble": "^3.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "watchify": "^3.11.1"
  }
}
