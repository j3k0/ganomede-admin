{
  "name": "admin",
  "version": "1.8.1",
  "api": "admin/v1",
  "description": "admin panel for ganomede",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "lintfix": "eslint --fix src/ tests/",
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --config vite.config.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/j3k0/ganomede-admin.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.4.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
